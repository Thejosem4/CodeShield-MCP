{
  "name": "codeshield-verify-mcp",
  "version": "0.6.1",
  "description": "MCP server and CLI that prevents LLM hallucinations by verifying code against known libraries and frameworks",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "codeshield": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && npm run remove-test-artifacts",
    "remove-test-artifacts": "node -p \"const fs=require('fs'),path=require('path');function r(d){fs.readdirSync(d).forEach(f=>{const p=path.join(d,f);fs.statSync(p).isDirectory()?r(p):(f.includes('.test.')&&fs.rmSync(p,{force:true}))})};r('dist')\"",
    "start": "node ./dist/index.js",
    "dev": "tsx src/index.ts",
    "cli": "node ./dist/cli.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "llm",
    "hallucination",
    "code-analysis",
    "typescript",
    "python",
    "javascript"
  ],
  "author": "Thejosem4",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thejosem4/CodeShield-MCP.git"
  },
  "bugs": {
    "url": "https://github.com/Thejosem4/CodeShield-MCP/issues"
  },
  "homepage": "https://github.com/Thejosem4/CodeShield-MCP#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
